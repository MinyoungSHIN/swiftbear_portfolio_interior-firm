{
  "color_system": {
    "primary":        { "hex": "#1E293B", "usage": "브랜드 대표색 — 딥 슬레이트 네이비, 헤더·주요 버튼·텍스트 강조" },
    "secondary":      { "hex": "#B8864E", "usage": "샴페인 골드 포인트 — CTA 버튼·배지·아이콘 강조·섹션 서브타이틀" },
    "accent":         { "hex": "#F8F7F5", "usage": "따뜻한 오프화이트 배경 — 교차 섹션 배경색 (프로세스·후기)" },
    "dark":           { "hex": "#0F172A", "usage": "딥 네이비 — 다크 배경 섹션 (신뢰 지표·상담 폼)" },
    "background":     { "hex": "#FFFFFF", "usage": "기본 흰 배경" },
    "text_primary":   { "hex": "#0F172A" },
    "text_secondary": { "hex": "#64748B" }
  },
  "typography": {
    "heading_font": {
      "name": "Cormorant Garamond",
      "google_fonts_url": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&display=swap",
      "weights": [400, 500, 600, 700]
    },
    "heading_font_kr": {
      "name": "Noto Serif KR",
      "google_fonts_url": "https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&display=swap",
      "weights": [400, 700]
    },
    "body_font": {
      "name": "DM Sans",
      "google_fonts_url": "https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap",
      "weights": [400, 500, 600]
    },
    "scale": {
      "h1": "clamp(2.5rem, 5vw, 4rem)",
      "h2": "clamp(1.8rem, 3vw, 2.5rem)",
      "h3": "1.4rem",
      "body": "1rem",
      "small": "0.875rem"
    }
  },
  "spacing": {
    "section_padding": "100px 0",
    "container_max_width": "1200px",
    "grid_gap": "32px"
  },
  "section_designs": [
    {
      "section_id": "hero",
      "layout": "풀스크린 (100svh) 배경 이미지 + 중앙 텍스트 오버레이",
      "background": "고급 인테리어 공간 사진 위 딥 슬레이트 그라디언트 오버레이 (rgba(15,23,42,0.82))",
      "animation": "텍스트 fade-up 0.8s, CTA 버튼 fade-up 1.2s",
      "special_effects": "스크롤 시 배경 parallax 효과"
    },
    {
      "section_id": "trust",
      "layout": "4컬럼 카운터 가로 배열",
      "background": "#0F172A (딥 네이비)",
      "animation": "카운터 숫자 롤업 애니메이션 (IntersectionObserver)",
      "special_effects": "없음"
    },
    {
      "section_id": "services",
      "layout": "2×2 카드 그리드",
      "background": "#FFFFFF",
      "animation": "카드 stagger fade-up (0.1s 간격)",
      "special_effects": "hover 시 카드 위로 4px 이동 + 샴페인 골드 하단 보더"
    },
    {
      "section_id": "process",
      "layout": "수평 스텝 타임라인 (모바일: 수직)",
      "background": "#F8F7F5 (웜 오프화이트)",
      "animation": "스텝별 순차 fade-in",
      "special_effects": "스텝 번호 딥 슬레이트 배경 + 샴페인 골드 링 테두리"
    },
    {
      "section_id": "portfolio",
      "layout": "3컬럼 그리드",
      "background": "#FFFFFF",
      "animation": "hover 시 이미지 1.07× 스케일 + 캡션 오버레이",
      "special_effects": "카테고리 필터 탭 (전체/주거/상업/오피스/부분)"
    },
    {
      "section_id": "testimonials",
      "layout": "3컬럼 카드 (모바일: 단일)",
      "background": "#F8F7F5 (웜 오프화이트)",
      "animation": "카드 fade-up stagger",
      "special_effects": "별점 샴페인 골드 아이콘, 큰따옴표 장식 요소"
    },
    {
      "section_id": "contact",
      "layout": "2컬럼 (연락처 왼쪽 | 폼 오른쪽)",
      "background": "#0F172A (딥 네이비)",
      "animation": "폼 슬라이드인 from right",
      "special_effects": "입력 필드 포커스 시 샴페인 골드 테두리 효과"
    }
  ],
  "ui_components": {
    "button_primary": {
      "style": "background: #B8864E; color: #fff; padding: 14px 32px; border-radius: 4px; font-weight: 600; letter-spacing: 0.05em; box-shadow: 0 4px 20px rgba(184,134,78,0.4)",
      "hover_effect": "background: #9B6E3A; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(184,134,78,0.45)"
    },
    "card": {
      "border_radius": "8px",
      "shadow": "0 4px 20px rgba(0,0,0,0.04)",
      "hover_effect": "translateY(-4px); box-shadow: 0 12px 32px rgba(30,41,59,0.10); border-bottom: 3px solid #B8864E"
    },
    "nav": {
      "style": "sticky top-0; background: rgba(255,255,255,0.97); backdrop-filter: blur(12px); border-bottom: 1px solid #E2E8F0",
      "mobile": "hamburger 메뉴 → 드로어"
    }
  }
}
